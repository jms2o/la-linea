generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  NOT_REQUIRED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  active    Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([active])
}

model Product {
  id                   String           @id @default(cuid())
  name                 String
  slug                 String           @unique
  description          String           @db.Text
  retailPrice          Decimal          @db.Decimal(10, 2)
  wholesalePrice       Decimal          @db.Decimal(10, 2)
  wholesaleMinQuantity Int
  categoryId           String
  active               Boolean          @default(true)
  category             Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images               ProductImage[]
  variants             ProductVariant[]
  orderItems           OrderItem[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([categoryId])
  @@index([active])
  @@index([slug])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([position])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  size       String
  color      String
  stock      Int         @default(0)
  sku        String?     @unique
  imageUrl   String?
  active     Boolean     @default(true)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([productId, size, color])
  @@index([productId])
  @@index([active])
  @@index([stock])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  address   String?
  city      String?
  notes     String?  @db.Text
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([createdAt])
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerId     String
  status         OrderStatus   @default(PENDING)
  subtotal       Decimal       @db.Decimal(10, 2)
  shippingCost   Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(NOT_REQUIRED)
  deliveryMethod String
  notes          String?       @db.Text
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items          OrderItem[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  productId        String?
  productVariantId String?
  productName      String
  size             String?
  color            String?
  quantity         Int
  unitPrice        Decimal         @db.Decimal(10, 2)
  subtotal         Decimal         @db.Decimal(10, 2)
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
}

model StoreSetting {
  id             String   @id @default("store")
  storeName      String
  whatsappNumber String?
  address        String?
  facebookUrl    String?
  instagramUrl   String?
  shippingCost   Decimal  @default(0) @db.Decimal(10, 2)
  orderMessage   String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
